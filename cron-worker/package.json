{
  "name": "spendguard-cron-worker",
  "version": "0.1.0",
  "description": "Scheduled job: evaluates validation rules against Meta Ads and sends alert emails",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "run-once": "node -e \"require('./src/runJob').runJob()\""
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.3",
    "@supabase/supabase-js": "^2.43.0",
    "axios": "^1.7.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "jose": "^6.2.2",
    "node-cron": "^3.0.3"
  }
}
